{
  "name": "calistus-glixymetric",
  "displayName": "GlixyMetric",
  "description": "A developer productivity extension that tracks coding activity ,time spent , and insights directly inside VS code .",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:glixymetric.dashboardView",
    "onCommand:calistus-glixymetric.openDashboard",
    "onCommand:calistus-glixymetric.openSidebar",
    "onCommand:calistus-glixymetric.viewTodayStats",
    "onCommand:calistus-glixymetric.setDailyGoals",
    "onCommand:calistus-glixymetric.clearDailyGoals",
    "onCommand:calistus-glixymetric.pauseTracking",
    "onCommand:calistus-glixymetric.testTracking"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "glixymetricDashboard",
          "title": "GlixyMetric",
          "icon": "media/glixymetric-activity.svg"
        }
      ]
    },
    "views": {
      "glixymetricDashboard": [
        {
          "type": "webview",
          "id": "glixymetric.dashboardView",
          "name": "Dashboard",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "calistus-glixymetric.testTracking",
        "title": "GlixyMetric: Test Tracking"
      },
      {
        "command": "calistus-glixymetric.viewTodayStats",
        "title": "GlixyMetric: View Today Stats",
        "description": "Show your coding stats for today"
      },
      {
        "command": "calistus-glixymetric.openDashboard",
        "title": "GlixyMetric: Open Dashboard",
        "description": "Open the GlixyMetric dashboard panel"
      },
      {
        "command": "calistus-glixymetric.openSidebar",
        "title": "GlixyMetric: Open Dashboard Sidebar",
        "description": "Open the optional GlixyMetric dashboard sidebar"
      },
      {
        "command": "calistus-glixymetric.setDailyGoals",
        "title": "GlixyMetric: Set Daily Goals",
        "description": "Set daily coding hours and commits targets"
      },
      {
        "command": "calistus-glixymetric.pauseTracking",
        "title": "GlixyMetric: Pause/Resume Tracking",
        "description": "Pause or resume activity tracking"
      },
      {
        "command": "calistus-glixymetric.clearDailyGoals",
        "title": "GlixyMetric: Clear Daily Goals",
        "description": "Clear your daily goals for today"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.4",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "recharts": "^2.8.0",
    "sql.js": "^1.8.0"
  }
}
